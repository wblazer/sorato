{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error"
  },
  "jsPlugins": ["./packages/oxlint-plugin/index.ts"],
  "rules": {
    "eslint/no-unused-expressions": "off",
    "unicorn/no-empty-file": "off",
    "sorato/no-dynamic-import": "error",
    "sorato/no-effect-all-step-sequencing": "error",
    "sorato/no-effect-as": "error",
    "sorato/no-effect-async": "error",
    "sorato/no-effect-bind": "error",
    "sorato/no-effect-do": "error",
    "sorato/no-effect-ladder": "error",
    "sorato/no-effect-never": "error",
    "sorato/no-effect-sync-console": "error",
    "sorato/no-effect-type-alias": "error",
    "sorato/no-effect-zip-right": "error",
    "sorato/no-fromnullable-nullish-coalesce": "error",
    "sorato/no-manual-effect-channels": "error",
    "sorato/no-match-effect-branch": "error",
    "sorato/no-model-overlay-cast": "error",
    "sorato/no-nested-effect-call": "error",
    "sorato/no-nested-effect-gen": "error",
    "sorato/no-option-as": "error",
    "sorato/no-option-boolean-normalization": "error",
    "sorato/no-pipe-ladder": "error",
    "sorato/no-return-null": "error",
    "sorato/no-runtime-runfork": "error",
    "sorato/no-string-sentinel-const": "error",
    "sorato/no-string-sentinel-return": "error"
  }
}
