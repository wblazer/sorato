{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error"
  },
  "options": {
    "reportUnusedDisableDirectives": "error"
  },
  "rules": {
    "eslint/no-unused-expressions": "off",
    "eslint/no-console": "error",
    "eslint/no-restricted-properties": [
      "error",
      {
        "object": "Schema",
        "property": "Class",
        "message": "Use Schema.Struct plus a same-name interface instead of Schema.Class."
      },
      {
        "object": "Schema",
        "property": "TaggedClass",
        "message": "Use Schema.TaggedStruct or Schema.TaggedUnion instead of Schema.TaggedClass."
      }
    ],
    "typescript/no-explicit-any": "error",
    "typescript/no-namespace": "error",
    "typescript/no-non-null-assertion": "error"
  },
  "overrides": [
    {
      "files": ["packages/server/src/**/*.ts"],
      "rules": {
        "node/no-process-env": "error"
      }
    },
    {
      "files": [
        "packages/server/src/data-dir.ts",
        "packages/server/src/logging.ts",
        "packages/server/src/runtime-config.ts"
      ],
      "rules": {
        "node/no-process-env": "off"
      }
    },
    {
      "files": ["packages/web/src/lib/index.ts"],
      "rules": {
        "unicorn/no-empty-file": "off"
      }
    },
    {
      "files": [
        "scripts/**",
        "packages/*/scripts/**",
        "packages/desktop/src/main.ts",
        "packages/desktop/src/integrated-server.ts"
      ],
      "rules": {
        "eslint/no-console": "off"
      }
    }
  ]
}
