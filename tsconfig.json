{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "noUnusedLocals": true
  },
  "include": [
    "packages/*/*.ts",
    "packages/*/src",
    "packages/*/tests",
    "packages/*/scripts"
  ],
  "exclude": [
    "node_modules",
    ".reference",
    "packages/*/build",
    "packages/*/dist",
    "packages/*/dist-*",
    "packages/*/.svelte-kit"
  ]
}
