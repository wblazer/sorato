{
  "name": "agents",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "effect-language-service patch",
    "eval": "bun run --filter @agents/evals start --",
    "typecheck": "bun --filter '*' typecheck && bun run --filter @agents/web check",
    "format": "biome format . --write",
    "format:check": "biome check . --formatter-enabled=true --linter-enabled=false",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --write",
    "effect-solutions": "bun node_modules/effect-solutions/dist/cli.js",
    "web": "bun run --filter @agents/web dev",
    "server": "bun run --filter @agents/agent dev"
  },
  "devDependencies": {
    "@typescript/native-preview": "beta",
    "@catenarycloud/linteffect": "0.0.4-0",
    "@effect/language-service": "^0.85.1",
    "@types/bun": "latest",
    "effect-solutions": "^0.4.13",
    "typescript": "^6"
  }
}
