{
  "name": "@sorato/desktop",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "bun run --parallel dev:web dev:bundle dev:electron",
    "dev:web": "bun run --filter @sorato/web dev --host ${SORATO_WEB_HOST:-127.0.0.1} --port ${SORATO_WEB_PORT:-5173} --strictPort",
    "dev:bundle": "tsdown --watch",
    "dev:electron": "node scripts/dev-electron.mjs",
    "build": "tsdown",
    "start": "node scripts/start-electron.mjs",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no desktop tests yet'"
  },
  "dependencies": {
    "effect": "4.0.0-beta.74",
    "electron": "^42.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsdown": "^0.22.1",
    "typescript": "^7.0.2"
  },
  "productName": "Sorato"
}
